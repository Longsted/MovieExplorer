@model MovieExplorer.Web.ViewModels.MovieDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5">

    <div class="row g-5">

        <div class="col-md-4">

            <img src="@Model.PosterUrl"
                 class="img-fluid shadow movie-poster"
                 alt="@Model.Title" />

        </div>

        <div class="col-md-8">

            <h1 class="display-5 fw-bold">
                @Model.Title
            </h1>

            <p class="text-muted fs-5">
                @Model.ReleaseYear
            </p>

            <div class="mb-3">

                @foreach (var genre in Model.Genres)
                {
                    <span class="badge text-bg-secondary me-1">
                        @genre
                    </span>
                }

            </div>

            <hr />

            <h4>Overview</h4>

            <p class="lead movie-overview">
                @Model.Overview
            </p>

            <button class="btn btn-primary btn-lg mt-3">
                Add to Wishlist
            </button>

        </div>

    </div>

</div>