@model MovieExplorer.Web.ViewModels.WishlistViewModel

@{
    ViewData["Title"] = "Wishlist";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="mb-1">My Wishlist</h1>

            <p class="text-muted mb-0">
                @Model.Movies.Count movie(s) saved
            </p>
        </div>

        <a asp-controller="Genres"
           asp-action="Index"
           class="btn btn-outline-primary">
            Browse Movies
        </a>

    </div>

    @if (!Model.Movies.Any())
    {
        <div class="wishlist-empty">

            <h3>Your wishlist is empty</h3>

            <p class="text-muted">
                Browse genres and save your favourite movies.
            </p>

            <a asp-controller="Genres"
               asp-action="Index"
               class="btn btn-primary">
                Browse Genres
            </a>

        </div>
    }
    else
    {
        <div class="row g-4">

            @foreach (var movie in Model.Movies)
            {
                <div class="col-sm-6 col-md-4 col-lg-3">

                    <div class="card h-100 shadow-sm">

                        <a asp-controller="Movies"
                           asp-action="Details"
                           asp-route-movieId="@movie.MovieId"
                           class="text-decoration-none text-dark">

                            <img src="@movie.PosterUrl"
                                 class="card-img-top"
                                 alt="@movie.Title"/>

                            <div class="card-body">

                                <h5 class="card-title">
                                    @movie.Title
                                </h5>

                                <p class="card-text text-muted">
                                    @movie.ReleaseYear
                                </p>

                            </div>

                        </a>

                        <div class="card-footer bg-white border-0">

                            <form asp-action="RemoveItem"
                                  asp-route-id="@movie.Id"
                                  method="post">

                                <button type="submit"
                                        class="btn btn-outline-danger w-100">
                                    Remove
                                </button>

                            </form>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>